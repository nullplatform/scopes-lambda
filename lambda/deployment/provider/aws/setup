#!/bin/bash

source "$SERVICE_PATH/utils/log"

log info "🔍 Validating AWS provider configuration..."

missing_vars=()

function validate_env_var() {
  local variable_name=$1
  local variable_value="${!variable_name}"

  if [ -z "$variable_value" ]; then
    echo "   ❌ $variable_name is missing"
    missing_vars+=("$variable_name")
  else
    log debug "   ✅ $variable_name=$variable_value"
  fi
}

validate_env_var AWS_REGION
validate_env_var TOFU_STATE_BUCKET

if [ ${#missing_vars[@]} -gt 0 ]; then
  echo ""
  echo "  🔧 How to fix:"
  echo "    Set the missing variable(s) in the nullplatform agent Helm installation:"
  for var in "${missing_vars[@]}"; do
    echo "      • $var"
  done
  echo ""
  return 1
fi

log info "✨ AWS provider configured successfully"
echo ""

RESOURCE_TAGS_JSON=${RESOURCE_TAGS_JSON:-"{}"}

# Ensure ManagedBy tag is always present — required by IAM policy on all Create* calls
RESOURCE_TAGS_JSON=$(echo "$RESOURCE_TAGS_JSON" | jq '. + {"ManagedBy": "custom-scope-role"}')

TOFU_VARIABLES=$(echo "$TOFU_VARIABLES" | jq \
  --arg aws_region "$AWS_REGION" \
  --arg tf_state_bucket "$TOFU_STATE_BUCKET" \
  --argjson resource_tags_json "$RESOURCE_TAGS_JSON" \
  '. + {aws_provider: {region: $aws_region, state_bucket: $tf_state_bucket}, provider_resource_tags_json: $resource_tags_json}')

TOFU_INIT_VARIABLES="$TOFU_INIT_VARIABLES -backend-config=bucket=$TOFU_STATE_BUCKET"
TOFU_INIT_VARIABLES="$TOFU_INIT_VARIABLES -backend-config=region=$AWS_REGION"
TOFU_INIT_VARIABLES="$TOFU_INIT_VARIABLES -backend-config=use_lockfile=true"

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
module_name="${script_dir}/modules"

if [[ -n $MODULES_TO_USE ]]; then
  MODULES_TO_USE="$MODULES_TO_USE,$module_name"
else
  MODULES_TO_USE="$module_name"
fi
