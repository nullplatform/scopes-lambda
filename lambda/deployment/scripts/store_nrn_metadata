#!/bin/bash
# Store ALB rule priority in NRN for idempotent re-deployments.
# This is the only value that must be persisted: it is assigned once
# (dynamically via listener query or from config) and reused on every
# re-deployment so the listener rule priority remains stable.

source "$SERVICE_PATH/utils/log"

log info "📝 Storing ALB rule priority in NRN..."

if [ -z "${SCOPE_NRN:-}" ]; then
  echo "❌ SCOPE_NRN is required" >&2
  echo "💡 Possible causes:" >&2
  echo "   - Scope context not available in the environment" >&2
  echo "   - NRN not passed from the deployment pipeline" >&2
  echo "🔧 How to fix:" >&2
  echo "   - Verify SCOPE_NRN is exported before this script runs" >&2
  echo "   - Check the deployment agent configuration" >&2
  return 1
fi

# Non-HTTP (event-driven) scopes skip ALB setup entirely and won't have this set.
if [ -z "${ALB_RULE_PRIORITY:-}" ]; then
  log debug "   ⏭️  ALB_RULE_PRIORITY not set — nothing to store (non-HTTP scope)"
  return 0
fi

log debug "   ✅ scope_nrn=$SCOPE_NRN"
log debug "   ✅ alb_rule_priority=$ALB_RULE_PRIORITY"

metadata=$(jq -n --argjson priority "$ALB_RULE_PRIORITY" '{"alb_rule_priority": $priority}')

# Prefix with "lambda." namespace
metadata=$(echo "$metadata" | jq 'with_entries(.key = "lambda." + .key)')
log debug "   ✅ Final metadata payload: $metadata"

echo ""
log info "   📡 Writing metadata to NRN=$SCOPE_NRN..."

np_output=$(np nrn patch \
  --nrn "$SCOPE_NRN" \
  --body "$metadata" \
  --format json 2>&1)
np_exit_code=$?

if [ $np_exit_code -ne 0 ]; then
  echo "❌ Failed to write NRN metadata to scope=$SCOPE_NRN" >&2
  echo "💡 Possible causes:" >&2
  echo "   - NRN service is unreachable" >&2
  echo "   - Invalid metadata JSON payload" >&2
  echo "   - Insufficient permissions to write to NRN" >&2
  echo "🔧 How to fix:" >&2
  echo "   - Check NRN service connectivity" >&2
  echo "   - Verify the metadata JSON is valid" >&2
  echo "   - Ensure the agent has write permissions to the NRN namespace" >&2
  echo "   📋 Error: $np_output" >&2
  return 1
fi

log debug "   ✅ Metadata stored successfully"
echo ""
log info "✨ ALB rule priority stored for scope=$SCOPE_NRN"
