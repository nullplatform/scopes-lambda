#!/bin/bash

# Fetch Scope Configuration: Retrieves cloud provider settings from vpc, cloud-providers,
# and scope-configurations providers. Exports networking, AWS identity, DNS, and state
# variables for downstream scripts.

log info "🔑 Fetching scope configuration..."

NRN=$(echo "$CONTEXT" | jq -r '.scope.nrn')
log debug "   ✅ nrn=$NRN"

DIMENSION_FILTER=$(echo "$CONTEXT" | jq -r '
  (.scope.dimensions // {}) | to_entries | map("\(.key):\(.value)") | join(",")
')

if [ -z "$DIMENSION_FILTER" ] || [ "$DIMENSION_FILTER" = "" ]; then
  log debug "   ✅ dimensions=none"
  PROVIDER_RESPONSE=$(np provider list --nrn "$NRN" --categories "vpc,scope-configurations,cloud-providers" --format json)
else
  log debug "   ✅ dimensions=$DIMENSION_FILTER"
  PROVIDER_RESPONSE=$(np provider list --nrn "$NRN" --categories "vpc,scope-configurations,cloud-providers" --dimensions "$DIMENSION_FILTER" --format json)
fi

for CATEGORY in vpc cloud-providers scope-configurations; do
  while IFS= read -r collision_key; do
    log warn "   ⚠️  Key collision in $CATEGORY: '$collision_key' is defined in multiple providers — last one wins"
  done < <(echo "$PROVIDER_RESPONSE" | jq -r --arg cat "$CATEGORY" \
    '[.results[] | select(.category == $cat) | .attributes | keys[]] | group_by(.) | map(select(length > 1) | .[0]) | .[]')
done

VPC_CONFIG=$(echo "$PROVIDER_RESPONSE" | jq -r \
  '[.results[] | select(.category == "vpc") | .attributes] | reduce .[] as $item ({}; . * $item)')

CLOUD_PROVIDER_CONFIG=$(echo "$PROVIDER_RESPONSE" | jq -r \
  '[.results[] | select(.category == "cloud-providers") | .attributes] | reduce .[] as $item ({}; . * $item)')

SCOPE_CONFIG=$(echo "$PROVIDER_RESPONSE" | jq -r \
  '[.results[] | select(.category == "scope-configurations") | .attributes] | reduce .[] as $item ({}; . * $item)')

# From vpc category
ALB_PUBLIC_LISTENER_ARN=$(echo "$VPC_CONFIG" | jq -r '.load_balancer.public.listener_arn // empty')
log debug "   ✅ alb_public_listener_arn=$ALB_PUBLIC_LISTENER_ARN"

ALB_PRIVATE_LISTENER_ARN=$(echo "$VPC_CONFIG" | jq -r '.load_balancer.private.listener_arn // empty')
log debug "   ✅ alb_private_listener_arn=$ALB_PRIVATE_LISTENER_ARN"

VPC_ID=$(echo "$VPC_CONFIG" | jq -r '.vpc.id // empty')
log debug "   ✅ vpc_id=$VPC_ID"

AWS_SUBNET_IDS=$(echo "$VPC_CONFIG" | jq -r '(.vpc.subnets // []) | join(",")')
log debug "   ✅ aws_subnet_ids=$AWS_SUBNET_IDS"

SECURITY_GROUP_IDS=$(echo "$VPC_CONFIG" | jq -r '(.vpc.security_groups // []) | join(",")')
log debug "   ✅ security_group_ids=$SECURITY_GROUP_IDS"

# From cloud-providers category
AWS_ACCOUNT_ID=$(echo "$CLOUD_PROVIDER_CONFIG" | jq -r '.account.id // empty')
log debug "   ✅ aws_account_id=$AWS_ACCOUNT_ID"

AWS_REGION=$(echo "$CLOUD_PROVIDER_CONFIG" | jq -r '.account.region // empty')
log debug "   ✅ aws_region=$AWS_REGION"

HOSTED_PUBLIC_ZONE_ID=$(echo "$CLOUD_PROVIDER_CONFIG" | jq -r '.networking.hosted_public_zone_id // empty')
log debug "   ✅ hosted_public_zone_id=$HOSTED_PUBLIC_ZONE_ID"

HOSTED_PRIVATE_ZONE_ID=$(echo "$CLOUD_PROVIDER_CONFIG" | jq -r '.networking.hosted_zone_id // empty')
log debug "   ✅ hosted_private_zone_id=$HOSTED_PRIVATE_ZONE_ID"

# From scope-configurations category
TOFU_STATE_BUCKET=$(echo "$SCOPE_CONFIG" | jq -r '.state.tofu_state_bucket // empty')
log debug "   ✅ tofu_state_bucket=$TOFU_STATE_BUCKET"

NULL_AGENT_LAYER_ARN=$(echo "$SCOPE_CONFIG" | jq -r '.agent.null_agent_layer_arn // empty')
log debug "   ✅ null_agent_layer_arn=$NULL_AGENT_LAYER_ARN"

export ALB_PUBLIC_LISTENER_ARN
export ALB_PRIVATE_LISTENER_ARN
export VPC_ID
export AWS_SUBNET_IDS
export SECURITY_GROUP_IDS
export AWS_ACCOUNT_ID
export AWS_REGION
export HOSTED_PUBLIC_ZONE_ID
export HOSTED_PRIVATE_ZONE_ID
export TOFU_STATE_BUCKET
export NULL_AGENT_LAYER_ARN

log info "✨ Scope configuration fetched successfully"
