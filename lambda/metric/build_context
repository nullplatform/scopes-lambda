#!/bin/bash

SCOPE_ID=$(echo "$CONTEXT" | jq -r '.scope.id')
SCOPE_NRN=$(echo "$CONTEXT" | jq -r '.scope.nrn')

if [ -z "$SCOPE_ID" ] || [ "$SCOPE_ID" = "null" ]; then
   echo "❌ Failed to extract scope ID from CONTEXT" >&2
   echo "💡 Possible causes:" >&2
   echo "   - CONTEXT variable is empty or malformed" >&2
   echo "   - scope.id field is missing from the context JSON" >&2
   echo "🔧 How to fix:" >&2
   echo "   - Verify the CONTEXT environment variable is set correctly" >&2
   echo "   - Check that the scope exists in nullplatform" >&2
   exit 1
fi

source "$SERVICE_PATH/utils/lambda_function_name"

METRIC_NAME=$(echo "$CONTEXT" | jq -r '.arguments.metric // "Invocations"')
METRIC_PERIOD=$(echo "$CONTEXT" | jq -r '.arguments.period // 300')
METRIC_START_TIME=$(echo "$CONTEXT" | jq -r '.arguments.start_time // ""')
METRIC_END_TIME=$(echo "$CONTEXT" | jq -r '.arguments.end_time // ""')

export SCOPE_ID
export SCOPE_NRN
export LAMBDA_FUNCTION_NAME
export METRIC_NAME
export METRIC_PERIOD
export METRIC_START_TIME
export METRIC_END_TIME