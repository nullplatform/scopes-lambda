#!/bin/bash
# Create IAM role for Lambda execution during scope creation
# This ensures the role is available for the placeholder Lambda

source "$SERVICE_PATH/utils/log"

log info "🔍 Setting up IAM role for Lambda..."

log info "   📡 Checking IAM configuration from providers..."

# Read role configuration from scope-configurations provider
use_dedicated_role=$(echo "$CONTEXT" | jq -r '.providers["scope-configurations"].lambda.use_dedicated_role // "false"')
role_name_template=$(echo "$CONTEXT" | jq -r '.providers["scope-configurations"].lambda.role_name_template // ""')
role_policies=$(echo "$CONTEXT" | jq -r '.providers["scope-configurations"].lambda.role_policies // "[]"')

log debug "   📋 use_dedicated_role=$use_dedicated_role"

# If using pre-existing dedicated role from provider configuration
if [ "$use_dedicated_role" = "true" ]; then
  dedicated_role_arn=$(echo "$CONTEXT" | jq -r '.providers["scope-configurations"].lambda.dedicated_role_arn // ""')
  dedicated_role_name=$(echo "$CONTEXT" | jq -r '.providers["scope-configurations"].lambda.dedicated_role_name // ""')

  if [ -n "$dedicated_role_arn" ] && [ "$dedicated_role_arn" != "null" ]; then
    log info "   ✅ Using dedicated role: $dedicated_role_arn"
    LAMBDA_ROLE_ARN="$dedicated_role_arn"
    LAMBDA_ROLE_NAME="$dedicated_role_name"
    export LAMBDA_ROLE_ARN
    export LAMBDA_ROLE_NAME
    exit 0
  fi

  echo "❌ Dedicated role enabled but no role ARN configured in scope-configurations provider" >&2
  echo "💡 Possible causes:" >&2
  echo "   - lambda.dedicated_role_arn not set in scope-configurations provider" >&2
  echo "🔧 How to fix:" >&2
  echo "   - Configure lambda.dedicated_role_arn in scope-configurations provider" >&2
  exit 1
fi

# Create dedicated role
log info "   📝 Creating dedicated IAM role..."

# Generate role name from template
iam_role_name="$role_name_template"
iam_role_name="${iam_role_name//\{scope_id\}/$SCOPE_ID}"
iam_role_name="${iam_role_name//\{scope_slug\}/$SCOPE_SLUG}"
iam_role_name="${iam_role_name//\{namespace_slug\}/$NAMESPACE_SLUG}"
iam_role_name="${iam_role_name//\{application_slug\}/$APPLICATION_SLUG}"
iam_role_name="${iam_role_name//\{account_slug\}/$ACCOUNT_SLUG}"
iam_role_name="${iam_role_name:0:64}"

log debug "   📋 role_name=$iam_role_name"

# Check if role already exists
existing_role=$(aws iam get-role --role-name "$iam_role_name" 2>&1 || echo "NOT_FOUND")

if ! echo "$existing_role" | grep -q "NoSuchEntity\|NOT_FOUND"; then
  log info "   ✅ Role already exists, reusing it"
  LAMBDA_ROLE_ARN=$(echo "$existing_role" | jq -r '.Role.Arn')
  LAMBDA_ROLE_NAME="$iam_role_name"
else
  # Create trust policy for Lambda
  trust_policy='{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Principal": {
          "Service": "lambda.amazonaws.com"
        },
        "Action": "sts:AssumeRole"
      }
    ]
  }'

  # Create the role
  create_output=$(aws iam create-role \
    --role-name "$iam_role_name" \
    --assume-role-policy-document "$trust_policy" \
    --description "Lambda execution role for $SCOPE_SLUG" \
    --tags Key=ManagedBy,Value=custom-scope-role \
    2>&1)
  create_exit_code=$?

  if [ $create_exit_code -ne 0 ]; then
    echo "❌ Failed to create IAM role '$iam_role_name'" >&2
    echo "💡 Possible causes:" >&2
    echo "   - Insufficient IAM permissions to create roles" >&2
    echo "   - Role name conflicts with an existing role in a different state" >&2
    echo "   - AWS API rate limiting or service issues" >&2
    echo "🔧 How to fix:" >&2
    echo "   - Verify the agent has iam:CreateRole permission" >&2
    echo "   - Check AWS CloudTrail for detailed error information" >&2
    echo "   - AWS error: $create_output" >&2
    exit 1
  fi

  LAMBDA_ROLE_ARN=$(echo "$create_output" | jq -r '.Role.Arn')
  LAMBDA_ROLE_NAME="$iam_role_name"

  log info "   ✅ Role created: $LAMBDA_ROLE_ARN"

  # Attach scoped CloudWatch Logs policy (replaces AWSLambdaBasicExecutionRole)
  logs_policy=$(cat <<POLICY
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": "logs:CreateLogGroup",
      "Resource": "arn:aws:logs:*:*:log-group:/aws/lambda/${LAMBDA_FUNCTION_NAME}"
    },
    {
      "Effect": "Allow",
      "Action": ["logs:CreateLogStream", "logs:PutLogEvents"],
      "Resource": "arn:aws:logs:*:*:log-group:/aws/lambda/${LAMBDA_FUNCTION_NAME}:*"
    }
  ]
}
POLICY
  )

  attach_output=$(aws iam put-role-policy \
    --role-name "$iam_role_name" \
    --policy-name "cloudwatch-logs" \
    --policy-document "$logs_policy" \
    2>&1)
  attach_exit_code=$?

  if [ $attach_exit_code -ne 0 ]; then
    echo "❌ Failed to attach CloudWatch Logs policy to '$iam_role_name'" >&2
    echo "💡 Possible causes:" >&2
    echo "   - Insufficient IAM permissions to put role policies" >&2
    echo "🔧 How to fix:" >&2
    echo "   - Verify the agent has iam:PutRolePolicy permission" >&2
    echo "   - AWS error: $attach_output" >&2
    exit 1
  fi

  log info "   ✅ Attached scoped CloudWatch Logs policy"

  # Check if VPC is enabled - attach VPC policy
  vpc_enabled=$(echo "$CONTEXT" | jq -r '.scope.capabilities.vpc_enabled // false')
  if [ "$vpc_enabled" = "true" ]; then
    vpc_attach_output=$(aws iam attach-role-policy \
      --role-name "$iam_role_name" \
      --policy-arn "arn:aws:iam::aws:policy/service-role/AWSLambdaVPCAccessExecutionRole" \
      2>&1)
    vpc_attach_exit_code=$?

    if [ $vpc_attach_exit_code -ne 0 ]; then
      echo "❌ Failed to attach AWSLambdaVPCAccessExecutionRole to '$iam_role_name'" >&2
      echo "💡 Possible causes:" >&2
      echo "   - Insufficient IAM permissions" >&2
      echo "🔧 How to fix:" >&2
      echo "   - Verify the agent has iam:AttachRolePolicy permission" >&2
      echo "   - AWS error: $vpc_attach_output" >&2
      exit 1
    fi

    log info "   ✅ Attached AWSLambdaVPCAccessExecutionRole (vpc_enabled=$vpc_enabled)"
  fi

  # Attach custom policies from provider configuration
  if [ "$role_policies" != "[]" ] && [ "$role_policies" != "null" ]; then
    policy_count=$(echo "$role_policies" | jq length)
    log info "   📝 Attaching $policy_count custom policies..."

    for i in $(seq 0 $((policy_count - 1))); do
      policy_name=$(echo "$role_policies" | jq -r ".[$i].name")
      policy_document=$(echo "$role_policies" | jq -r ".[$i].policy")

      put_output=$(aws iam put-role-policy \
        --role-name "$iam_role_name" \
        --policy-name "$policy_name" \
        --policy-document "$policy_document" \
        2>&1)
      put_exit_code=$?

      if [ $put_exit_code -ne 0 ]; then
        echo "❌ Failed to attach custom policy '$policy_name' to '$iam_role_name'" >&2
        echo "💡 Possible causes:" >&2
        echo "   - Invalid policy document JSON" >&2
        echo "   - Insufficient IAM permissions" >&2
        echo "🔧 How to fix:" >&2
        echo "   - Validate the policy document in scope-configurations lambda.role_policies" >&2
        echo "   - AWS error: $put_output" >&2
        exit 1
      fi

      log debug "   ✅ Attached custom policy: $policy_name"
    done
  fi
fi

# Export variables
export LAMBDA_ROLE_ARN
export LAMBDA_ROLE_NAME

log info "✨ IAM role setup complete: role_arn=$LAMBDA_ROLE_ARN"
