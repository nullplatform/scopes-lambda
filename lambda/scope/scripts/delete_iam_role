#!/bin/bash
# Delete IAM role during scope deletion
# Only deletes roles that were created by the scope (use_dedicated_role=false)

source "$SERVICE_PATH/utils/log"

log info "🔍 Cleaning up IAM role..."

# Read role configuration from scope-configurations provider
use_dedicated_role=$(echo "$CONTEXT" | jq -r '.providers["scope-configurations"].lambda.use_dedicated_role // "false"')

log debug "   📋 use_dedicated_role=$use_dedicated_role"

if [ "$use_dedicated_role" = "true" ]; then
  log info "   ✅ Using externally managed dedicated role - skipping IAM cleanup"
  exit 0
fi

# Role was created by the scope - read stored role info from NRN
nrn_output=$(np nrn read --nrn "$SCOPE_NRN" --namespace aws --format json 2>&1 || echo "{}")
role_name=$(echo "$nrn_output" | jq -r '.AWS_DEDICATED_ROLE_NAME // ""')

log debug "   📋 role_name=$role_name"

if [ -z "$role_name" ] || [ "$role_name" = "null" ]; then
  log info "   ✅ No role name found in NRN - skipping IAM cleanup"
  exit 0
fi

# Check if role exists
log info "   📡 Checking if role '$role_name' exists..."

existing_role=$(aws iam get-role --role-name "$role_name" 2>&1 || echo "NOT_FOUND")

if echo "$existing_role" | grep -q "NoSuchEntity\|NOT_FOUND"; then
  log info "   ✅ Role '$role_name' does not exist - skipping deletion"
  exit 0
fi

# Detach managed policies
log info "   📝 Detaching managed policies from '$role_name'..."

attached_policies=$(aws iam list-attached-role-policies \
  --role-name "$role_name" \
  --query 'AttachedPolicies[].PolicyArn' \
  --output text 2>/dev/null || echo "")

for policy_arn in $attached_policies; do
  log debug "   📝 Detaching: $policy_arn"
  aws iam detach-role-policy \
    --role-name "$role_name" \
    --policy-arn "$policy_arn" \
    2>/dev/null || true
done

# Delete inline policies
log info "   📝 Deleting inline policies from '$role_name'..."

inline_policies=$(aws iam list-role-policies \
  --role-name "$role_name" \
  --query 'PolicyNames[]' \
  --output text 2>/dev/null || echo "")

for policy_name in $inline_policies; do
  log debug "   📝 Deleting inline policy: $policy_name"
  aws iam delete-role-policy \
    --role-name "$role_name" \
    --policy-name "$policy_name" \
    2>/dev/null || true
done

# Delete the role
log info "   📡 Deleting IAM role '$role_name'..."

delete_output=$(aws iam delete-role --role-name "$role_name" 2>&1)
delete_exit_code=$?

if [ $delete_exit_code -ne 0 ]; then
  echo "❌ Failed to delete IAM role '$role_name'" >&2
  echo "💡 Possible causes:" >&2
  echo "   - Role still has instance profiles attached" >&2
  echo "   - Insufficient IAM permissions" >&2
  echo "🔧 How to fix:" >&2
  echo "   - Remove all instance profiles from the role first" >&2
  echo "   - Verify the agent has iam:DeleteRole permission" >&2
  echo "   - AWS error: $delete_output" >&2
  exit 1
fi

log info "   ✅ IAM role '$role_name' deleted successfully"
log info "✨ IAM cleanup complete"
