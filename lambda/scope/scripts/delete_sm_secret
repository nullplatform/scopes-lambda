#!/bin/bash
# Delete all Secrets Manager secrets for a scope
# Called during scope deletion to clean up any remaining deployment secrets

source "$SERVICE_PATH/utils/log"

log info "🗑️  Cleaning up Secrets Manager secrets for scope..."

if [ -z "${SCOPE_ID:-}" ]; then
  echo "❌ SCOPE_ID is not set" >&2
  echo "💡 Possible causes:" >&2
  echo "   - build_context did not export SCOPE_ID" >&2
  echo "🔧 How to fix:" >&2
  echo "   - Ensure scope/build_context runs before this script" >&2
  return 1
fi

log debug "   ✅ scope_id=$SCOPE_ID"

# Only run when parameters strategy is secretsmanager
parameters_strategy="${PARAMETERS_STRATEGY:-env}"
if [ "$parameters_strategy" != "secretsmanager" ]; then
  log info "   ⏭️  Parameters strategy is '$parameters_strategy' - skipping Secrets Manager cleanup"
  return 0
fi

# List all secrets for this scope (prefix: nullplatform/<scope_id>/)
secrets_json=$(aws secretsmanager list-secrets \
  --filters "Key=name,Values=nullplatform/${SCOPE_ID}/" \
  --query 'SecretList[*].Name' \
  --output json \
  2>&1)
list_exit=$?

if [ $list_exit -ne 0 ]; then
  log warn "   ⚠️  Failed to list secrets for scope $SCOPE_ID: $secrets_json"
  return 0
fi

secret_count=$(echo "$secrets_json" | jq 'length')
log debug "   ✅ secrets_found=$secret_count"

if [ "$secret_count" -eq 0 ]; then
  log info "   ⏭️  No secrets found for scope $SCOPE_ID - skipping"
  return 0
fi

echo "$secrets_json" | jq -r '.[]' | while read -r secret_name; do
  log info "   📝 Deleting secret: $secret_name..."
  delete_output=$(aws secretsmanager delete-secret \
    --secret-id "$secret_name" \
    --force-delete-without-recovery \
    2>&1)
  delete_exit=$?
  if [ $delete_exit -ne 0 ]; then
    if echo "$delete_output" | grep -q "ResourceNotFoundException"; then
      log debug "   ✅ Secret '$secret_name' already deleted - skipping"
    else
      log warn "   ⚠️  Failed to delete secret '$secret_name': $delete_output"
    fi
  else
    log debug "   ✅ Secret deleted: $secret_name"
  fi
done

echo ""
log info "✨ Secrets Manager cleanup complete for scope=$SCOPE_ID"
