#!/bin/bash

source "$SERVICE_PATH/utils/log"
source "$SERVICE_PATH/utils/get_config_value"

log info "🔍 Configuring IAM role for deployment..."

# Execution-role name = <prefix><function>-role. The prefix is configurable
# (scope-config provider > LAMBDA_EXECUTION_ROLE_PREFIX env > default), but it
# MUST keep matching the iam:CreateRole/PassRole Resource constraint of the
# assume role's policy in lambda/setup (arn:aws:iam::*:role/np-lambda-* or
# .../nullplatform-*); otherwise CreateRole/PassRole are denied. The default
# preserves the historical "np-lambda-".
exec_role_prefix=$(get_config_value \
  --provider '.providers["scope-configurations"].lambda.execution_role_prefix' \
  --env LAMBDA_EXECUTION_ROLE_PREFIX \
  --default 'np-lambda-')

iam_role_name="${exec_role_prefix}${LAMBDA_FUNCTION_NAME}-role"
iam_role_name="${iam_role_name:0:64}"

# Warn (don't block) if the prefix falls outside the policy's allowed prefixes.
case "$exec_role_prefix" in
  np-lambda-*|nullplatform-*) : ;;
  *) log warn "   ⚠️  execution_role_prefix='$exec_role_prefix' is outside the assume role's IAM policy constraint (np-lambda-* / nullplatform-*); CreateRole/PassRole may be denied unless that policy is updated" ;;
esac

log debug "   📋 role_name=$iam_role_name"

role_output=$(aws iam get-role --role-name "$iam_role_name" 2>&1)

if [ $? -eq 0 ]; then
  # Role already exists — Tofu will manage it (no changes expected) but skip propagation wait.
  # iam_create_role must stay true so count=1 is preserved in the Terraform state;
  # setting it to false would flip count to 0 and cause Terraform to destroy the role.
  log debug "   ✅ role exists (no propagation wait needed)"
  propagation_duration="0s"
else
  # Role does not exist — Tofu will create it and wait for IAM propagation.
  propagation_wait="${IAM_PROPAGATION_WAIT_SECONDS:-20}"
  propagation_duration="${propagation_wait}s"
  log debug "   📋 role will be created by Tofu (propagation_wait=${propagation_duration})"
fi

vpc_enabled=$(echo "$CONTEXT" | jq -r '.scope.capabilities.vpc_enabled // false')
log debug "   📋 vpc_enabled=$vpc_enabled"

permissions_boundary=$(echo "$CONTEXT" | jq -r '.providers["scope-configurations"].lambda.permissions_boundary // ""')
if [ -z "$permissions_boundary" ]; then
  permissions_boundary="${IAM_PERMISSIONS_BOUNDARY:-}"
fi
log debug "   📋 permissions_boundary=$permissions_boundary"

TOFU_VARIABLES=$(echo "$TOFU_VARIABLES" | jq \
  --arg role_name "$iam_role_name" \
  --arg scope_id "$SCOPE_ID" \
  --arg function_name "$LAMBDA_FUNCTION_NAME" \
  --arg function_name "$LAMBDA_FUNCTION_NAME" \
  --arg duration "$propagation_duration" \
  --arg boundary "$permissions_boundary" \
  --argjson vpc_enabled "$vpc_enabled" \
  '. + {iam_create_role: true, iam_role_name: $role_name, iam_scope_id: $scope_id, iam_function_name: $function_name, iam_propagation_duration: $duration, iam_vpc_enabled: $vpc_enabled, iam_permissions_boundary: $boundary}')

log info "✨ IAM configured"
echo ""

# Add module to composition list
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
module_name="${script_dir}/modules"

if [[ -n $MODULES_TO_USE ]]; then
  MODULES_TO_USE="$MODULES_TO_USE,$module_name"
else
  MODULES_TO_USE="$module_name"
fi
