#!/bin/bash
# Fetch Lambda logs from CloudWatch

if [ -z "${LAMBDA_LOG_GROUP_NAME:-}" ]; then
   echo "❌ Log group name not available" >&2
   echo "💡 Possible causes:" >&2
   echo "   - build_context failed to resolve the Lambda function name" >&2
   echo "   - LAMBDA_LOG_GROUP_NAME was not exported by build_context" >&2
   echo "🔧 How to fix:" >&2
   echo "   - Check that build_context ran successfully" >&2
   echo "   - Verify the NRN contains LAMBDA_FUNCTION_NAME" >&2
   exit 1
fi

# Get log parameters from context or defaults
start_time="${LOG_START_TIME:-}"
end_time="${LOG_END_TIME:-}"
limit="${LOG_LIMIT:-100}"
filter="${LOG_FILTER:-}"

# Calculate default time range (last 1 hour)
if [ -z "$end_time" ]; then
   end_time=$(date +%s)000
fi

if [ -z "$start_time" ]; then
   start_time=$(( $(date +%s) - 3600 ))000
fi

# Build filter pattern argument
filter_arg=""
if [ -n "$filter" ]; then
   filter_arg="--filter-pattern \"$filter\""
fi

# Fetch logs
result=$(aws logs filter-log-events \
   --log-group-name "$LAMBDA_LOG_GROUP_NAME" \
   --start-time "$start_time" \
   --end-time "$end_time" \
   --limit "$limit" \
   ${filter_arg} \
   --query 'events[].{datetime:timestamp,message:message}' \
   --output json 2>&1)

if [ $? -ne 0 ]; then
   echo "❌ Failed to fetch logs from CloudWatch" >&2
   echo "💡 Possible causes:" >&2
   echo "   - Log group '$LAMBDA_LOG_GROUP_NAME' does not exist" >&2
   echo "   - AWS credentials lack logs:FilterLogEvents permission" >&2
   echo "   - The Lambda function has not been invoked yet" >&2
   echo "🔧 How to fix:" >&2
   echo "   - Verify the log group exists in CloudWatch" >&2
   echo "   - Check the agent IAM role permissions" >&2
   echo "   - Invoke the Lambda function to generate logs" >&2
   exit 1
fi

sorted_logs=$(echo "$result" | jq '[.[] | .datetime = ((.datetime / 1000) | todate)] | sort_by(.datetime)')

jq -n \
   --argjson results "$sorted_logs" \
   --arg token "" \
   '{results: $results, next_page_token: $token}'
