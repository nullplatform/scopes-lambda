#!/bin/bash

SCOPE_ID=$(echo "$CONTEXT" | jq -r '.scope.id')
SCOPE_NRN=$(echo "$CONTEXT" | jq -r '.scope.nrn')

if [ -z "$SCOPE_ID" ] || [ "$SCOPE_ID" = "null" ]; then
   echo "❌ Failed to extract scope ID from CONTEXT" >&2
   echo "💡 Possible causes:" >&2
   echo "   - CONTEXT variable is empty or malformed" >&2
   echo "   - scope.id field is missing from the context JSON" >&2
   echo "🔧 How to fix:" >&2
   echo "   - Verify the CONTEXT environment variable is set correctly" >&2
   echo "   - Check that the scope exists in nullplatform" >&2
   exit 1
fi

source "$SERVICE_PATH/utils/lambda_function_name"

lambda_info=$(aws lambda get-function --function-name "$LAMBDA_FUNCTION_NAME" --output json 2>/dev/null || echo "{}")
LAMBDA_FUNCTION_ARN=$(echo "$lambda_info" | jq -r '.Configuration.FunctionArn // ""')
LAMBDA_ROLE_ARN=$(echo "$lambda_info" | jq -r '.Configuration.Role // ""')
SCOPE_DOMAIN=""

export SCOPE_ID
export SCOPE_NRN
export LAMBDA_FUNCTION_NAME
export LAMBDA_FUNCTION_ARN
export LAMBDA_ROLE_ARN
export SCOPE_DOMAIN

echo "Diagnose build_context completed"
echo "   SCOPE_ID=$SCOPE_ID"
echo "   SCOPE_NRN=$SCOPE_NRN"
echo "   LAMBDA_FUNCTION_NAME=$LAMBDA_FUNCTION_NAME"
echo "   LAMBDA_FUNCTION_ARN=$LAMBDA_FUNCTION_ARN"
echo "   LAMBDA_ROLE_ARN=$LAMBDA_ROLE_ARN"
echo "   SCOPE_DOMAIN=$SCOPE_DOMAIN"
